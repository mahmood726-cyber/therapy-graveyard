# TherapyGraveyard — environment template
#
# Copy this file to `.env` and fill in real values before running.
# Never commit your .env (it is gitignored).

# AACT password (paired with AACT_USER above)
AACT_PASSWORD=

# AACT username (free signup at https://aact.ctti-clinicaltrials.org/users/sign_up)
AACT_USER=
